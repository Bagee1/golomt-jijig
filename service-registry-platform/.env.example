# All values below are MANDATORY when running the services manually (mvn spring-boot:run):
# application.yml has no password/secret fallbacks, so a service fails fast when one is missing.
# The full-stack `docker compose up -d --build` works without this file — dev-safe
# defaults live in docker-compose.yml; copy this file to .env to override them.
POSTGRES_DB=service_registry
POSTGRES_USER=registry_user
POSTGRES_PASSWORD=registry_password
POSTGRES_PORT=5432

PLATFORM_API_PORT=8080
# JWT_SECRET must be IDENTICAL for platform-api and banking-transfer-service:
# platform-api issues the token, banking-transfer-service validates it with the same key.
JWT_SECRET=change-this-dev-only-secret-at-least-32-characters

BANKING_TRANSFER_SERVICE_PORT=8084
BANKING_DB_HOST=localhost
BANKING_DB_PORT=5433
BANKING_DB_NAME=banking_transfer
BANKING_DB_USER=banking_user
BANKING_DB_PASSWORD=banking_password

# Optional transfer limits (these are the defaults if unset)
BANKING_MAX_PER_TRANSFER=5000000.00
BANKING_DAILY_OUTGOING_TOTAL=10000000.00

