# All values below are MANDATORY when running the services manually (mvn spring-boot:run):
# application.yml has no password/secret fallbacks, so a service fails fast when one is missing.
# The full-stack `docker compose up -d --build` works without this file — dev-safe
# defaults live in docker-compose.yml; copy this file to .env to override them.
POSTGRES_DB=service_registry
POSTGRES_USER=registry_user
POSTGRES_PASSWORD=registry_password
POSTGRES_PORT=5432

PLATFORM_API_PORT=8080
# JWT_SECRET must be IDENTICAL for all three services (platform-api, banking-transfer-service,
# deposit-service): platform-api issues the token, the other two validate it with the same key.
JWT_SECRET=change-this-dev-only-secret-at-least-32-characters

BANKING_TRANSFER_SERVICE_PORT=8084
BANKING_DB_HOST=localhost
BANKING_DB_PORT=5433
BANKING_DB_NAME=banking_transfer
BANKING_DB_USER=banking_user
BANKING_DB_PASSWORD=banking_password

# Optional transfer limits (these are the defaults if unset)
BANKING_MAX_PER_TRANSFER=5000000.00
BANKING_DAILY_OUTGOING_TOTAL=10000000.00

# --- deposit-service (term deposits, funds/pays out through the banking transfer API) ---
DEPOSIT_SERVICE_PORT=8085
DEPOSIT_DB_HOST=localhost
DEPOSIT_DB_PORT=5434
DEPOSIT_DB_NAME=deposit_service
DEPOSIT_DB_USER=deposit_user
DEPOSIT_DB_PASSWORD=deposit_password
# When running deposit-service manually, point it at the other two services:
BANKING_API_URL=http://localhost:8084
PLATFORM_API_URL=http://localhost:8080
# Service account used ONLY for settlement payouts. The password MUST match the
# BCrypt hash seeded in platform-api db/seed-dev/V6 (default demo password below).
# A wrong value locks the account after 5 tries and breaks payouts (502).
SVC_DEPOSIT_USERNAME=svc-deposit
SVC_DEPOSIT_PASSWORD=svc-deposit-demo-123
# Optional deposit bounds (defaults if unset)
DEPOSIT_MIN_AMOUNT=100000.00
DEPOSIT_MAX_AMOUNT=3000000.00

# Frontend build-time API URLs (baked into the banking app image)
VITE_DEPOSIT_API_URL=http://localhost:8085

